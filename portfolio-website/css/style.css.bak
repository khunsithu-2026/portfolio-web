/* =========================================
   VARIABLES & THEMING
   ========================================= */
:root {
  --primary-color: #0f172a;
  --secondary-color: #3b82f6;
  --accent: #5570f8;
  --accent-hover: #3b52d9;
  --text-main: #334155;
  --text-light: #64748b;
  --text-muted: #94a3b8;
  --bg-color: #ffffff;
  --bg-alt: #f8fafc;
  --border-light: #e2e8f0;
  --radius-md: 12px;
  --radius-lg: 16px;
  --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
  --shadow-card: 0 10px 30px rgba(15, 23, 42, 0.06);
  --shadow-card-hover: 0 24px 48px rgba(15, 23, 42, 0.1);
  --transition: all 0.3s ease;
  /* Navbar + main content share the same max width */
  --layout-max-width: 1200px;
}

/* =========================================
   RESET & FOUNDATION
   ========================================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Inter', sans-serif;
  color: var(--text-main);
  background-color: var(--bg-color);
  line-height: 1.6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

a {
  text-decoration: none;
  color: var(--text-main);
  transition: var(--transition);
}

ul {
  list-style: none;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

/* =========================================
   UTILITIES
   ========================================= */
.container {
  width: min(90%, var(--layout-max-width));
  max-width: var(--layout-max-width);
  margin-left: auto;
  margin-right: auto;
}

/* =========================================
   NAVIGATION BAR
   ========================================= */
.navbar {
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 1000;
  padding: 1.2rem 0;
  border-bottom: 1px solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.nav-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  font-size: 1.8rem;
  font-weight: 800;
  color: #0b1120;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  letter-spacing: -0.5px;
}

.logo i {
  color: #5570f8;
  font-size: 2rem;
}

.nav-links {
  flex: 1;
  display: flex;
  justify-content: center;
}

.nav-links ul {
  display: flex;
  gap: 2.5rem;
}

.nav-links a {
  font-weight: 500;
  font-size: 1.05rem;
  color: #334155;
  transition: var(--transition);
}

.nav-links a:hover,
.nav-links a.active {
  color: #5570f8;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 1.2rem;
}

.btn-download {
  padding: 0.75rem 2rem;
  font-size: 1rem;
}

.menu-toggle {
  display: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: #0b1120;
}

/* Responsive Navigation */
@media screen and (max-width: 900px) {
  .menu-toggle {
    display: block;
  }
  
  .nav-actions .btn-download {
    display: none; /* Hide button on mobile menu unless inside menu */
  }

  .nav-links {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
    transition: clip-path 0.4s ease-in-out;
  }

  .nav-links.active {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  }

  .nav-links ul {
    flex-direction: column;
    align-items: center;
    padding: 2rem 0;
    gap: 1.5rem;
  }
}

/* =========================================
   BUTTONS
   ========================================= */
.btn {
  display: inline-block;
  padding: 0.8rem 1.8rem;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  transition: var(--transition);
  border: 2px solid transparent;
}

.btn-primary {
  background-color: #5570f8 !important;
  color: #fff !important;
  border: none !important;
}

.btn-primary:hover {
  background-color: #3b52d9 !important;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(85, 112, 248, 0.3);
}

.btn-pill {
  border-radius: 50px !important;
  padding: 0.9rem 2.2rem;
  font-size: 1rem;
}

.btn-dark {
  background-color: #0b1120 !important;
  color: #fff !important;
  border: none !important;
}

.btn-dark:hover {
  background-color: #1e293b !important;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(11, 17, 32, 0.2);
}

.btn-outline {
  background-color: transparent !important;
  color: #0b1120 !important;
  border: 2px solid #e2e8f0 !important;
}

.btn-outline:hover {
  border-color: #5570f8 !important;
  color: #5570f8 !important;
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(85, 112, 248, 0.15);
}

/* =========================================
   HERO SECTION
   ========================================= */
.hero-section {
  flex: 1 0 auto;
  min-height: calc(100vh - 80px);
  display: flex;
  align-items: center;
  padding: 3rem 0;
  position: relative;
  overflow: hidden;
  background: linear-gradient(165deg, #ffffff 0%, #f8fafc 42%, #eef2ff 100%);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: min(55vw, 480px);
  height: min(55vw, 480px);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(85, 112, 248, 0.09) 0%, transparent 68%);
  pointer-events: none;
}

.hero-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
}

.hero-content {
  flex: 1.2;
  padding-right: 2rem;
  z-index: 2;
}

.greeting {
  color: #5570f8;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.greeting i {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #e0e7ff;
  color: #4f46e5;
  font-size: 0.95rem;
}

.hero-points {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2rem;
}

.hero-points span {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.45rem 0.75rem;
  border-radius: 999px;
  font-size: 0.86rem;
  font-weight: 600;
  color: #475569;
  background: #f1f5f9;
  border: 1px solid #e2e8f0;
}

.hero-points i {
  color: #5570f8;
}

.name {
  font-size: 4.5rem;
  font-weight: 800;
  color: #0b1120;
  line-height: 1.1;
  margin-bottom: 0.5rem;
  letter-spacing: -1px;
}

.role {
  font-size: 1.8rem;
  color: #94a3b8;
  margin-bottom: 1.8rem;
  font-weight: 400;
}

.role-highlight {
  color: #0b1120;
  font-weight: 800;
}

.bio {
  font-size: 1.1rem;
  max-width: 480px;
  margin-bottom: 2.5rem;
  color: #94a3b8;
  line-height: 1.6;
}

.hero-buttons {
  display: flex;
  gap: 1.2rem;
}

.hero-image {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  position: relative;
}

.hero-visual {
  position: relative;
  width: 100%;
  max-width: 400px;
  z-index: 2;
}

.hero-visual-bg {
  position: absolute;
  inset: -12% -8% -8% -5%;
  z-index: 0;
  border-radius: 32px;
  background:
    radial-gradient(ellipse 70% 55% at 20% 30%, rgba(99, 102, 241, 0.18) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 85% 70%, rgba(34, 211, 238, 0.14) 0%, transparent 50%),
    linear-gradient(160deg, rgba(248, 250, 252, 0.9) 0%, rgba(238, 242, 255, 0.65) 100%);
  border: 1px solid rgba(226, 232, 240, 0.9);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.hero-photo-block {
  position: relative;
  z-index: 1;
  margin: 0;
  padding: 1.5rem 1.5rem 0;
}

.hero-photo-ring {
  padding: 3px;
  border-radius: 22px;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 45%, #22d3ee 100%);
  box-shadow: 0 20px 50px rgba(79, 70, 229, 0.22);
}

.hero-person-img {
  width: 100%;
  height: auto;
  display: block;
  max-height: min(420px, 58vh);
  object-fit: cover;
  object-position: center top;
  border-radius: 19px;
  background: #f1f5f9;
}

.hero-photo-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 0.75rem 1.25rem;
  margin-top: 1rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: #64748b;
}

.hero-status i {
  font-size: 0.45rem;
  margin-right: 0.35rem;
  color: #22c55e;
  vertical-align: middle;
}

.hero-location i {
  margin-right: 0.35rem;
  color: #5570f8;
}

.hero-tech-strip {
  position: relative;
  z-index: 1;
  margin: 1.5rem 1.25rem 1.25rem;
  padding: 0.85rem 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid #e2e8f0;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.hero-tech-title {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #475569;
}

.hero-tech-title i {
  color: #5570f8;
  font-size: 0.85rem;
}

.hero-tech-icons {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.hero-tech-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.15rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hero-tech-icon:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.1);
}

.hero-tech-html {
  background: #fff7ed;
  color: #ea580c;
}

.hero-tech-css {
  background: #eff6ff;
  color: #0284c7;
}

.hero-tech-js {
  background: #fefce8;
  color: #ca8a04;
}

.hero-tech-git {
  background: #f8fafc;
  color: #f05032;
}

/* Responsive Hero */
@media screen and (max-width: 900px) {
  .hero-container {
    flex-direction: column;
    text-align: center;
  }
  
  .hero-content {
    flex: 1;
    padding-right: 0;
  }
  
  .bio {
    margin: 0 auto 2.5rem auto;
  }
  
  .hero-buttons {
    justify-content: center;
  }

  .hero-points {
    justify-content: center;
  }
  
  .greeting {
    justify-content: center;
  }
  
  .name {
    font-size: 3rem;
  }
  
  .role {
    font-size: 1.5rem;
  }
  
  .hero-image {
    width: 100%;
    margin-top: 2rem;
    justify-content: center;
  }

  .hero-visual {
    max-width: 360px;
  }
}

@media screen and (max-width: 640px) {
  .hero-visual-bg {
    inset: -8% -4% -6% -4%;
    border-radius: 24px;
  }

  .hero-photo-block {
    padding: 1rem 1rem 0;
  }

  .hero-photo-ring {
    border-radius: 18px;
  }

  .hero-person-img {
    border-radius: 15px;
    max-height: 50vh;
  }

  .hero-tech-strip {
    margin: 1.25rem 0.75rem 1rem;
    flex-direction: column;
    align-items: stretch;
    text-align: center;
  }

  .hero-tech-icons {
    justify-content: center;
  }
}

/* =========================================
   GENERAL SECTIONS
   ========================================= */
.section-title {
  text-align: center;
  font-size: 2.5rem;
  color: var(--primary-color);
  margin-bottom: 3rem;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 4px;
  background-color: var(--secondary-color);
  border-radius: 2px;
}

/* =========================================
   HOME SKILLS SECTION
   ========================================= */
.home-skills-section {
  padding: 5rem 0 6rem;
  background-color: #ffffff;
}

.home-skills-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.25rem;
}

.home-skill-card {
  background: #ffffff;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 2rem 1.5rem;
  transition: var(--transition);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.home-skill-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-card-hover);
  border-color: rgba(85, 112, 248, 0.25);
}

.home-skill-card i {
  font-size: 1.8rem;
  margin-bottom: 0;
}

.skill-icon-wrap {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  border: 1px solid #c7d2fe;
  margin: 0 auto 0.95rem;
}

.skill-icon-html {
  color: #f97316 !important;
}

.skill-icon-css {
  color: #0ea5e9 !important;
}

.skill-icon-js {
  color: #eab308 !important;
}

.skill-icon-responsive {
  color: #8b5cf6 !important;
}

.home-skill-card:hover .skill-icon-wrap {
  background: linear-gradient(145deg, #5570f8, #3b52d9);
  border-color: #3b52d9;
}

.home-skill-card:hover .skill-icon-wrap i {
  color: #ffffff;
}

.home-skill-card h3 {
  color: #0b1120;
  font-size: 1.1rem;
  margin-bottom: 0.65rem;
}

.home-skill-card p {
  color: var(--text-light);
  font-size: 0.94rem;
  line-height: 1.65;
  max-width: 28ch;
}

.home-skill-card.skill-html .skill-icon-wrap {
  background: #fff7ed;
  border-color: #fed7aa;
}

.home-skill-card.skill-css .skill-icon-wrap {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.home-skill-card.skill-js .skill-icon-wrap {
  background: #fefce8;
  border-color: #fde68a;
}

.home-skill-card.skill-responsive .skill-icon-wrap {
  background: #f5f3ff;
  border-color: #ddd6fe;
}

@media screen and (max-width: 1000px) {
  .home-skills-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media screen and (max-width: 640px) {
  .home-skills-section {
    padding: 4rem 0 5rem;
  }

  .home-skills-grid {
    grid-template-columns: 1fr;
  }
}

/* =========================================
   FOOTER
   ========================================= */
.footer {
  position: relative;
  background: linear-gradient(180deg, #0f172a 0%, #0b1120 45%, #080c14 100%);
  color: #ffffff;
  padding: 4.5rem 0 2.25rem;
  margin-top: auto;
  overflow: hidden;
}

.footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, #5570f8 20%, #7c8ff0 50%, #5570f8 80%, transparent);
  opacity: 0.85;
}

.footer::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -15%;
  width: min(520px, 70vw);
  height: min(520px, 70vw);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(85, 112, 248, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.footer .container {
  position: relative;
  z-index: 1;
}

.footer-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.85fr) minmax(0, 1.1fr);
  gap: 3rem 3.5rem;
  align-items: start;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(148, 163, 184, 0.12);
}

.footer-brand .logo {
  color: #ffffff;
  justify-content: flex-start;
  margin-bottom: 1.25rem;
}

.footer .logo i {
  color: #5570f8;
}

.footer-desc {
  color: #94a3b8;
  margin: 0;
  max-width: 28rem;
  line-height: 1.75;
  font-size: 1rem;
}

.footer-heading {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #64748b;
  margin: 0 0 1.35rem;
}

.footer-links ul {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.footer-links a {
  color: #cbd5e1;
  font-weight: 500;
  font-size: 1rem;
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  transition: color 0.2s ease, transform 0.2s ease;
}

.footer-links a::before {
  content: '';
  width: 0;
  height: 1px;
  background: #5570f8;
  transition: width 0.2s ease;
}

.footer-links a:hover {
  color: #ffffff;
  transform: translateX(4px);
}

.footer-links a:hover::before {
  width: 10px;
}

.footer-cta {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 16px;
  padding: 1.75rem 1.85rem;
  box-shadow: 0 24px 48px rgba(0, 0, 0, 0.25);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.footer-cta:hover {
  border-color: rgba(85, 112, 248, 0.35);
  box-shadow: 0 28px 56px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(85, 112, 248, 0.08);
}

.footer-cta > p {
  color: #94a3b8;
  font-size: 0.98rem;
  line-height: 1.7;
  margin: 0 0 1.35rem;
}

.footer-cta .cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
  font-size: 0.95rem;
  padding: 0.85rem 1.75rem;
}

.footer-cta .cta-btn i {
  font-size: 0.85em;
  transition: transform 0.25s ease;
}

.footer-cta .cta-btn:hover i {
  transform: translateX(4px);
}

.social-links {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.85rem;
}

.social-links a {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 44px;
  height: 44px;
  background-color: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(148, 163, 184, 0.1);
  border-radius: 12px;
  color: #cbd5e1;
  font-size: 1.1rem;
  transition: background-color 0.25s ease, color 0.25s ease, transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
}

.social-links a:hover {
  background-color: #5570f8;
  border-color: #5570f8;
  color: #ffffff;
  transform: translateY(-3px);
  box-shadow: 0 12px 24px rgba(85, 112, 248, 0.35);
}

.footer-bottom {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  justify-content: space-between;
  align-items: center;
  gap: 1.5rem;
  padding-top: 2rem;
  color: #64748b;
  font-size: 0.9rem;
}

.footer-copyright p {
  margin: 0;
  letter-spacing: 0.02em;
}

.footer-bottom .social-links {
  justify-content: flex-end;
}

@media screen and (max-width: 900px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 2rem;
  }

  .footer-brand {
    grid-column: 1 / -1;
  }

  .footer-links {
    justify-self: start;
  }

  .footer-cta {
    justify-self: stretch;
  }
}

@media screen and (max-width: 768px) {
  .footer {
    padding: 3.5rem 0 2rem;
  }

  .footer-grid {
    grid-template-columns: 1fr;
    text-align: center;
    padding-bottom: 2.5rem;
  }

  .footer-brand .logo {
    justify-content: center;
  }

  .footer-desc {
    margin-left: auto;
    margin-right: auto;
  }

  .footer-links ul {
    align-items: center;
  }

  .footer-links a:hover {
    transform: none;
  }

  .footer-cta {
    text-align: center;
    max-width: none;
  }

  .footer-cta .cta-btn {
    width: 100%;
    justify-content: center;
  }

  .footer-bottom {
    flex-direction: column;
    text-align: center;
  }

  .footer-bottom .social-links {
    justify-content: center;
  }
}

/* =========================================
   ABOUT PAGE
   ========================================= */
.about-page-section {
  flex: 1 0 auto;
  padding: 4.5rem 0 5.5rem;
  min-height: calc(100vh - 80px - 200px);
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 50%, #f8fafc 100%);
  position: relative;
  overflow: hidden;
}

.about-page-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: min(900px, 90vw);
  height: 280px;
  background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(85, 112, 248, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.about-inner {
  position: relative;
  z-index: 1;
}

.page-header {
  text-align: center;
  margin-bottom: 3.5rem;
}

.page-header .section-title {
  margin-bottom: 1rem;
  font-size: 2.5rem;
  color: #0b1120;
  font-weight: 800;
}

.page-header .section-title::after {
  display: none;
}

.page-header .section-subtitle {
  max-width: 36rem;
  margin: -0.75rem auto 0;
}

.about-page-intro {
  margin-bottom: 3rem;
}

.about-kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #5570f8;
  margin-bottom: 0.75rem;
}

.about-kicker i {
  font-size: 0.85rem;
  opacity: 0.9;
}

.about-content-wrapper {
  display: grid;
  grid-template-columns: minmax(280px, 380px) minmax(0, 1fr);
  align-items: stretch;
  gap: 3.5rem;
  width: 100%;
}

.about-visual {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  align-self: stretch;
}

.about-visual-bg {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
  background:
    radial-gradient(ellipse 80% 70% at 30% 20%, rgba(99, 102, 241, 0.12) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(34, 211, 238, 0.1) 0%, transparent 50%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.65) 0%, rgba(248, 250, 252, 0.95) 100%);
  border: 1px solid rgba(226, 232, 240, 0.9);
  z-index: 0;
}

.about-visual-inner {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 1.75rem 1.5rem;
  min-height: 100%;
  width: 100%;
}

.about-photo-ring {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 340px;
  padding: 4px;
  border-radius: 22px;
  background: linear-gradient(145deg, #6366f1, #8b5cf6 50%, #22d3ee);
  box-shadow: 0 24px 50px rgba(79, 70, 229, 0.2);
}

.about-visual .about-photo-ring img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 18px;
  object-fit: cover;
  aspect-ratio: 4 / 5;
  background: #e2e8f0;
}

.about-sidebar-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #64748b;
  margin: 0 0 0.65rem;
  width: 100%;
  max-width: 340px;
}

.about-skills-block {
  width: 100%;
  max-width: 340px;
  margin-top: 1.25rem;
}

.about-skill-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}

.about-skill-chip {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  background: #ffffff;
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.about-skill-chip:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
}

.about-skill-chip:nth-child(1) {
  color: #ea580c;
}

.about-skill-chip:nth-child(2) {
  color: #0284c7;
}

.about-skill-chip:nth-child(3) {
  color: #ca8a04;
}

.about-skill-chip:nth-child(4) {
  color: #0ea5e9;
}

.about-skill-chip:nth-child(5) {
  color: #f05032;
}

.about-contact-block {
  width: 100%;
}

.about-contact-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.about-contact-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  font-size: 0.86rem;
  line-height: 1.45;
}

.about-contact-list > li > i {
  color: #5570f8;
  width: 1.15rem;
  flex-shrink: 0;
  margin-top: 0.12rem;
  text-align: center;
}

.about-contact-list a {
  color: #334155;
  font-weight: 600;
  word-break: break-word;
}

.about-contact-list a:hover {
  color: #5570f8;
}

.about-contact-address span {
  display: block;
  font-weight: 500;
  color: #64748b;
}

.about-sidebar-bottom {
  margin-top: auto;
  width: 100%;
  max-width: 340px;
  display: flex;
  flex-direction: column;
  gap: 1.15rem;
  padding-top: 0.35rem;
}

.about-quick-tags {
  position: relative;
  z-index: 2;
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 100%;
}

.about-quick-tags li {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.88rem;
  font-weight: 600;
  color: #475569;
  padding: 0.55rem 0.85rem;
  background: #ffffff;
  border: 1px solid var(--border-light);
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
}

.about-quick-tags i {
  color: #5570f8;
  width: 1.1rem;
  text-align: center;
}

.about-social-block {
  width: 100%;
}

.about-social-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}

.about-social-link {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  color: #64748b;
  background: #ffffff;
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow-sm);
  transition: color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.about-social-link:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(15, 23, 42, 0.1);
}

.about-social-email:hover {
  color: #ffffff;
  background: #5570f8;
  border-color: #5570f8;
}

.about-social-phone:hover {
  color: #ffffff;
  background: #059669;
  border-color: #059669;
}

.about-social-github:hover {
  color: #ffffff;
  background: #0b1120;
  border-color: #0b1120;
}

.about-social-linkedin:hover {
  color: #ffffff;
  background: #0a66c2;
  border-color: #0a66c2;
}

.about-social-twitter:hover {
  color: #ffffff;
  background: #0ea5e9;
  border-color: #0ea5e9;
}

.about-social-telegram:hover {
  color: #ffffff;
  background: #229ed9;
  border-color: #229ed9;
}

.about-text-card {
  flex: 1;
  min-width: 0;
  background: #ffffff;
  padding: 2.75rem 3rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1px solid var(--border-light);
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1.35rem;
}

.about-text-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 2rem;
  right: 2rem;
  height: 4px;
  border-radius: 0 0 6px 6px;
  background: linear-gradient(90deg, #6366f1, #8b5cf6, #22d3ee);
}

.about-text-card h3 {
  font-size: 1.85rem;
  color: #0b1120;
  font-weight: 800;
  line-height: 1.2;
  padding-top: 0.35rem;
}

.highlight {
  color: #5570f8;
}

.about-text-card .lead {
  font-size: 1.1rem;
  font-weight: 600;
  color: #334155;
  margin: -0.35rem 0 0;
}

.about-highlights {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
}

.about-highlight {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  padding: 0.85rem 1rem;
  border-radius: 12px;
  background: #f8fafc;
  border: 1px solid #f1f5f9;
  transition: var(--transition);
}

.about-highlight:hover {
  border-color: rgba(85, 112, 248, 0.25);
  background: #ffffff;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
}

.about-highlight-icon {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  color: #4f46e5;
  font-size: 1rem;
}

.about-highlight strong {
  display: block;
  font-size: 0.92rem;
  color: #0b1120;
  margin-bottom: 0.2rem;
}

.about-highlight span {
  font-size: 0.86rem;
  color: #64748b;
  line-height: 1.45;
}

.about-desc p {
  color: #64748b;
  margin-bottom: 1rem;
  line-height: 1.75;
  font-size: 0.98rem;
}

.about-desc p:last-child {
  margin-bottom: 0;
}

.about-stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 0.25rem;
}

.about-stat-box {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding: 1rem 1.1rem;
  border-radius: 14px;
  background: linear-gradient(145deg, #f8fafc, #ffffff);
  border: 1px solid #e2e8f0;
}

.about-stat-box > i {
  font-size: 1.35rem;
  color: #5570f8;
  opacity: 0.9;
}

.about-stat-num {
  display: block;
  font-size: 1.65rem;
  font-weight: 800;
  color: #0b1120;
  line-height: 1.1;
}

.about-stat-label {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #64748b;
}

.about-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  margin-top: 0.5rem;
}

.about-actions .btn-outline i {
  margin-left: 0.35rem;
}

/* Responsive About */
@media screen and (max-width: 900px) {
  .about-content-wrapper {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .about-visual {
    max-width: 400px;
    width: 100%;
    margin: 0 auto;
    min-height: auto;
  }

  .about-visual-inner {
    min-height: auto;
    padding: 1.5rem 1.25rem 1.75rem;
  }

  .about-sidebar-bottom {
    margin-top: 1.5rem;
  }

  .about-text-card {
    padding: 2.25rem 1.75rem;
    width: 100%;
  }

  .about-text-card::before {
    left: 1.25rem;
    right: 1.25rem;
  }
}

@media screen and (max-width: 540px) {
  .about-stats-row {
    grid-template-columns: 1fr;
  }

  .about-actions {
    flex-direction: column;
  }

  .about-actions .btn {
    width: 100%;
    text-align: center;
  }
}

/* =========================================
   PROJECTS PAGE
   ========================================= */
.projects-page-section {
  flex: 1 0 auto;
  padding: 5rem 0;
  min-height: calc(100vh - 80px - 200px);
  background-color: var(--bg-alt);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 2.5rem;
}

.project-card {
  background-color: #ffffff;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: var(--transition);
  border: 1px solid var(--border-light);
}

.project-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-card-hover);
  border-color: rgba(85, 112, 248, 0.2);
}

.project-img-wrapper {
  position: relative;
  overflow: hidden;
  background: #e2e8f0;
}

.project-card-img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.project-card:hover .project-card-img {
  transform: scale(1.05);
}

/* Glassmorphism Overlay */
.project-links {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  background-color: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1.5rem;
  opacity: 0;
  transition: all 0.4s ease;
}

.project-card:hover .project-links {
  opacity: 1;
}

.project-link-icon {
  width: 50px;
  height: 50px;
  background-color: #ffffff;
  color: #0b1120;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.2rem;
  transform: translateY(20px);
  transition: all 0.4s ease;
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
}

.project-card:hover .project-link-icon {
  transform: translateY(0);
}

.project-link-icon:hover {
  background-color: #5570f8;
  color: #ffffff;
  transform: translateY(-5px);
}

.project-info {
  padding: 2rem;
}

.project-info h3 {
  font-size: 1.35rem;
  color: #0b1120;
  margin-bottom: 0.8rem;
  font-weight: 700;
}

.project-info p {
  color: #64748b;
  font-size: 0.95rem;
  margin-bottom: 1.5rem;
  line-height: 1.6;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
}

.project-tags span {
  background-color: #f1f5f9;
  color: #5570f8;
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.4rem 0.9rem;
  border-radius: 20px;
}

/* =========================================
   BLOG PAGE
   ========================================= */
.blog-page-section {
  flex: 1 0 auto;
  padding: 4rem 0 5.5rem;
  min-height: calc(100vh - 80px - 200px);
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 45%, #f8fafc 100%);
  position: relative;
  overflow: hidden;
}

.blog-page-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: min(960px, 92vw);
  height: 240px;
  background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(85, 112, 248, 0.09) 0%, transparent 70%);
  pointer-events: none;
}

.blog-layout {
  position: relative;
  z-index: 1;
  width: 100%;
}

.blog-page-intro {
  margin-bottom: 3rem;
}

.blog-kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #5570f8;
  margin-bottom: 0.75rem;
}

.blog-kicker i {
  font-size: 0.85rem;
}

.section-subtitle {
  color: var(--text-light);
  font-size: 1.05rem;
  line-height: 1.65;
  margin-top: -0.25rem;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 2rem;
}

.blog-card {
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: var(--transition);
  border: 1px solid var(--border-light);
  display: flex;
  flex-direction: column;
}

.blog-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-card-hover);
  border-color: rgba(85, 112, 248, 0.22);
}

.blog-img-wrapper {
  position: relative;
  overflow: hidden;
  height: 200px;
  background: #e2e8f0;
}

.blog-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.blog-card:hover .blog-card-img {
  transform: scale(1.06);
}

.blog-category {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background-color: rgba(85, 112, 248, 0.95);
  color: #ffffff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.4rem 0.8rem;
  border-radius: 999px;
  z-index: 10;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  box-shadow: 0 4px 14px rgba(85, 112, 248, 0.35);
}

.blog-category-alt {
  background: rgba(14, 165, 233, 0.95);
  box-shadow: 0 4px 14px rgba(14, 165, 233, 0.3);
}

.blog-category-accent {
  background: rgba(139, 92, 246, 0.95);
  box-shadow: 0 4px 14px rgba(139, 92, 246, 0.3);
}

.blog-content {
  padding: 1.65rem 1.75rem 1.75rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

.blog-meta {
  margin-bottom: 0.65rem;
}

.blog-date {
  color: #94a3b8;
  font-size: 0.82rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.blog-title {
  font-size: 1.22rem;
  margin-bottom: 0.75rem;
  line-height: 1.35;
}

.blog-title a {
  color: #0b1120;
  transition: color 0.3s;
}

.blog-title a:hover {
  color: #5570f8;
}

.blog-excerpt {
  color: #64748b;
  font-size: 0.92rem;
  margin-bottom: 1.25rem;
  line-height: 1.6;
  flex-grow: 1;
}

.blog-read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-weight: 600;
  color: #5570f8;
  font-size: 0.9rem;
  transition: all 0.3s;
  align-self: flex-start;
}

.blog-read-more i {
  font-size: 0.85em;
  transition: transform 0.25s ease;
}

.blog-read-more:hover {
  gap: 0.65rem;
  color: #3b50c0;
}

.blog-read-more:hover i {
  transform: translateX(4px);
}

@media screen and (max-width: 768px) {
  .blog-grid {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .blog-page-section {
    padding: 3rem 0 4rem;
  }

  .blog-img-wrapper {
    height: 180px;
  }
}

/* =========================================
   ARTICLE PAGE
   ========================================= */
.article-page-section {
  flex: 1 0 auto;
  padding: 2.5rem 0 5rem;
  background: linear-gradient(180deg, #f1f5f9 0%, #f8fafc 35%, #f1f5f9 100%);
  position: relative;
  overflow: hidden;
}

.article-page-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: min(900px, 95vw);
  height: 200px;
  background: radial-gradient(ellipse 90% 100% at 50% 0%, rgba(85, 112, 248, 0.07) 0%, transparent 65%);
  pointer-events: none;
}

.article-layout {
  width: 100%;
  position: relative;
  z-index: 1;
}

.btn-back {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 1.75rem;
  transition: color 0.3s ease, transform 0.3s ease;
}

.btn-back:hover {
  color: #5570f8;
  transform: translateX(-4px);
}

.article-header {
  margin-bottom: 1.75rem;
  max-width: 100%;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #e2e8f0;
}

.article-header .blog-category {
  position: static;
  display: inline-block;
  margin-bottom: 1rem;
}

.article-title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  color: #0b1120;
  line-height: 1.25;
  font-weight: 800;
  margin-bottom: 1.25rem;
}

.article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  color: #64748b;
  font-size: 0.95rem;
  font-weight: 500;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.author-avatar {
  width: 32px;
  height: 32px;
  background-color: #f1f5f9;
  color: #5570f8;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1rem;
}

.author-name {
  color: #0b1120;
  font-weight: 700;
}

.meta-divider {
  color: #cbd5e1;
}

.article-hero-image {
  margin-bottom: 2.25rem;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 20px 50px rgba(15, 23, 42, 0.06);
  background: #ffffff;
}

/* Article hero: 3 images — two stacked left, one tall right */
.article-hero-grid--split {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  grid-template-rows: 1fr 1fr;
  min-height: min(360px, 44vh);
  max-height: min(520px, 52vh);
  gap: 1px;
  background: #e2e8f0;
}

.article-hero-grid-item {
  margin: 0;
  padding: 0;
  overflow: hidden;
  min-height: 0;
  background: #f1f5f9;
  display: flex;
  align-items: stretch;
}

.article-hero-grid--split .article-hero-grid-item:nth-child(1) {
  grid-column: 1;
  grid-row: 1;
}

.article-hero-grid--split .article-hero-grid-item:nth-child(2) {
  grid-column: 1;
  grid-row: 2;
}

.article-hero-grid--split .article-hero-grid-item:nth-child(3) {
  grid-column: 2;
  grid-row: 1 / -1;
}

.article-hero-grid-item img {
  width: 100%;
  flex: 1;
  min-height: 140px;
  object-fit: cover;
  display: block;
}

.hero-placeholder {
  font-size: 5rem;
}

.article-columns {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
  gap: 2rem;
  align-items: stretch;
}

.article-main {
  background-color: #ffffff;
  padding: 2.5rem 2.75rem 2.25rem;
  border-radius: var(--radius-lg);
  box-shadow: 0 4px 24px rgba(15, 23, 42, 0.05);
  border: 1px solid var(--border-light);
  min-width: 0;
  height: 100%;
  box-sizing: border-box;
}

.article-content {
  color: #334155;
  font-size: 1.05rem;
  line-height: 1.8;
}

.article-content h2 {
  font-size: 1.65rem;
  color: #0b1120;
  margin-top: 2.25rem;
  margin-bottom: 0.85rem;
  font-weight: 700;
  scroll-margin-top: 6rem;
}

.article-content h2:first-of-type {
  margin-top: 0;
}

.article-content h3 {
  font-size: 1.3rem;
  color: #0b1120;
  margin-top: 1.75rem;
  margin-bottom: 0.65rem;
  font-weight: 700;
  scroll-margin-top: 6rem;
}

.article-content p {
  margin-bottom: 1.35rem;
}

.article-lead {
  font-size: 1.2rem;
  color: #64748b;
  line-height: 1.7;
  font-weight: 500;
  margin-bottom: 2rem !important;
}

.article-content blockquote {
  font-size: 1.1rem;
  font-style: italic;
  color: #0b1120;
  padding: 1.35rem 1.5rem;
  margin: 2rem 0;
  background-color: #f8fafc;
  border-left: 4px solid #5570f8;
  border-radius: 0 10px 10px 0;
  line-height: 1.65;
}

.article-content ul, .article-content ol {
  margin-bottom: 1.35rem;
  padding-left: 1.35rem;
}

.article-content ul {
  list-style: disc;
}

.article-content ol {
  list-style: decimal;
}

.article-content li {
  margin-bottom: 0.65rem;
}

.article-content code {
  background-color: #f1f5f9;
  color: #7c3aed;
  padding: 0.15rem 0.45rem;
  border-radius: 6px;
  font-family: ui-monospace, 'Cascadia Code', 'Segoe UI Mono', monospace;
  font-size: 0.9em;
}

.article-sidebar {
  position: relative;
  min-width: 0;
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.article-sidebar-stack {
  position: sticky;
  top: 6.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  flex: 1;
  width: 100%;
  min-height: 0;
  max-height: min(calc(100vh - 7rem), 100%);
}

.article-sidebar-card {
  background: #ffffff;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 20px rgba(15, 23, 42, 0.05);
  padding: 1.35rem 1.25rem;
}

.article-sidebar-team {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
}

.article-team-intro {
  font-size: 0.82rem;
  color: #64748b;
  margin: -0.35rem 0 1rem;
  line-height: 1.45;
}

.article-team-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}

.article-team-member {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.article-team-avatar {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  color: #4f46e5;
  border: 1px solid #e0e7ff;
}

.article-team-avatar-alt {
  background: linear-gradient(145deg, #ecfdf5, #d1fae5);
  color: #059669;
  border-color: #a7f3d0;
}

.article-team-avatar-alt2 {
  background: linear-gradient(145deg, #fef3c7, #fde68a);
  color: #b45309;
  border-color: #fcd34d;
}

.article-team-meta strong {
  display: block;
  font-size: 0.9rem;
  font-weight: 700;
  color: #0b1120;
  line-height: 1.25;
}

.article-team-meta span {
  font-size: 0.76rem;
  color: #64748b;
  line-height: 1.3;
}

.article-sidebar-heading {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #64748b;
  margin: 0 0 0.9rem;
}

.article-sidebar-heading i {
  color: #5570f8;
  font-size: 0.85rem;
}

.article-toc {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.article-toc a {
  display: block;
  padding: 0.45rem 0.6rem;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 600;
  color: #475569;
  border-left: 3px solid transparent;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
}

.article-toc a:hover {
  background: #f8fafc;
  color: #5570f8;
  border-left-color: #5570f8;
}

.article-sidebar-divider {
  height: 1px;
  background: #e2e8f0;
  margin: 1.15rem 0;
}

.article-sidebar-share-btns {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.article-sidebar-social-btn {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  font-size: 1.05rem;
  transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
}

.article-sidebar-social-btn:hover {
  background: #5570f8;
  border-color: #5570f8;
  color: #ffffff;
  transform: translateY(-2px);
}

.article-sidebar-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.article-sidebar-avatar {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  color: #4f46e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.article-sidebar-author strong {
  display: block;
  font-size: 0.95rem;
  color: #0b1120;
  margin-bottom: 0.15rem;
}

.article-sidebar-author span {
  font-size: 0.78rem;
  color: #64748b;
  line-height: 1.35;
}

.article-footer {
  margin-top: 2.5rem;
  padding-top: 1.75rem;
  border-top: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.25rem;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.article-tags .tag {
  background-color: #f1f5f9;
  color: #64748b;
  padding: 0.4rem 0.75rem;
  border-radius: 8px;
  font-size: 0.82rem;
  font-weight: 600;
  transition: all 0.3s;
  cursor: default;
}

.article-tags .tag:hover {
  background-color: #5570f8;
  color: #ffffff;
}

.article-share {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  color: #0b1120;
  font-weight: 600;
  font-size: 0.9rem;
}

.article-share-inline a {
  width: 36px;
  height: 36px;
  background-color: #f1f5f9;
  color: #64748b;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s;
}

.article-share-inline a:hover {
  background-color: #5570f8;
  color: #ffffff;
  transform: translateY(-2px);
}

@media screen and (max-width: 900px) {
  .article-columns {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .article-main {
    height: auto;
  }

  .article-sidebar {
    height: auto;
  }

  .article-sidebar-stack {
    position: static;
    max-height: none;
    flex: none;
  }

  .article-sidebar-card {
    padding: 1.25rem;
  }

  .article-toc {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .article-toc a {
    border-left: none;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
  }

  .article-toc a:hover {
    border-color: #5570f8;
  }
}

@media screen and (max-width: 768px) {
  .article-page-section {
    padding: 1.75rem 0 3.5rem;
  }

  .article-main {
    padding: 1.75rem 1.35rem 1.5rem;
  }

  .article-title {
    font-size: 1.65rem;
  }

  .article-hero-grid--split {
    grid-template-columns: 1fr;
    grid-template-rows: repeat(3, minmax(150px, min(30vh, 240px)));
  }

  .article-hero-grid--split .article-hero-grid-item:nth-child(1),
  .article-hero-grid--split .article-hero-grid-item:nth-child(2),
  .article-hero-grid--split .article-hero-grid-item:nth-child(3) {
    grid-column: 1;
    grid-row: auto;
  }

  .article-footer {
    flex-direction: column;
    align-items: flex-start;
  }
}

/* =========================================
   CONTACT PAGE
   ========================================= */
.contact-page-section {
  flex: 1 0 auto;
  padding: 4rem 0 5.5rem;
  min-height: calc(100vh - 80px - 200px);
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 45%, #f8fafc 100%);
  position: relative;
  overflow: hidden;
}

.contact-page-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: min(960px, 92vw);
  height: 240px;
  background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(85, 112, 248, 0.09) 0%, transparent 70%);
  pointer-events: none;
}

.contact-inner {
  position: relative;
  z-index: 1;
}

.contact-page-intro {
  margin-bottom: 3rem;
}

.contact-kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #5570f8;
  margin-bottom: 0.75rem;
}

.contact-kicker i {
  font-size: 0.85rem;
  opacity: 0.9;
}

.contact-wrapper {
  display: grid;
  grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
  gap: 2rem;
  align-items: stretch;
  width: 100%;
}

.contact-info-card {
  background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
  padding: 2rem 1.75rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1px solid var(--border-light);
  display: flex;
  flex-direction: column;
  gap: 1.35rem;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
}

.info-item-clean {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.contact-info-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #eef2ff, #e0e7ff);
  color: #4f46e5;
  font-size: 1rem;
  border: 1px solid rgba(224, 231, 255, 0.9);
}

.contact-info-body h4 {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 0.35rem;
}

.contact-info-body p {
  color: #334155;
  font-size: 0.95rem;
  font-weight: 600;
  line-height: 1.45;
  margin: 0;
}

.contact-info-body a {
  color: #5570f8;
  font-weight: 600;
}

.contact-info-body a:hover {
  color: #3b52d9;
}

.contact-social-block {
  margin-top: auto;
  padding-top: 1.25rem;
  border-top: 1px solid #f1f5f9;
}

.contact-social-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 0.85rem;
}

.social-icons-clean {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.social-icons-clean a {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 1rem;
  background: #f8fafc;
  border: 1px solid var(--border-light);
  transition: var(--transition);
}

.social-icons-clean a:hover {
  color: #ffffff;
  background: #5570f8;
  border-color: #5570f8;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(85, 112, 248, 0.35);
}

.contact-form-wrapper {
  min-width: 0;
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.contact-form-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  padding: 2.5rem 2.75rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1px solid var(--border-light);
  min-height: 0;
  box-sizing: border-box;
}

.contact-form-heading {
  font-size: 1.35rem;
  font-weight: 800;
  color: #0b1120;
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
}

.contact-form-lead {
  font-size: 0.95rem;
  color: #64748b;
  line-height: 1.55;
  margin-bottom: 1.75rem;
}

.contact-form-clean {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  min-height: 0;
}

.form-row {
  display: flex;
  gap: 1.25rem;
}

.form-group-clean {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  min-width: 0;
}

.form-group-clean label {
  font-size: 0.88rem;
  color: #475569;
  font-weight: 600;
}

.form-group-clean input,
.form-group-clean textarea {
  width: 100%;
  padding: 0.85rem 1rem;
  background-color: #f8fafc;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  color: #334155;
  font-family: inherit;
  font-size: 0.95rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  outline: none;
}

.form-group-clean input:hover,
.form-group-clean textarea:hover {
  border-color: #cbd5e1;
}

.form-group-clean input::placeholder,
.form-group-clean textarea::placeholder {
  color: #94a3b8;
}

.form-group-clean input:focus,
.form-group-clean textarea:focus {
  background-color: #ffffff;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(85, 112, 248, 0.18);
}

.full-width {
  flex: 100%;
}

.form-submit-wrapper {
  display: flex;
  justify-content: flex-start;
  margin-top: 0.25rem;
}

.form-submit-wrapper .btn {
  padding: 0.85rem 2rem;
}

@media screen and (max-width: 900px) {
  .contact-wrapper {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .contact-info-card {
    padding: 2rem 1.5rem;
  }

  .contact-form-card {
    padding: 2rem 1.5rem;
  }

  .form-row {
    flex-direction: column;
    gap: 1.5rem;
  }
}

/* =========================================
   TEAM SECTION
   ========================================= */
.team-section {
  padding: 5rem 0;
  background-color: var(--bg-alt);
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.team-card {
  background: #ffffff;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  padding: 2.5rem 2rem;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.team-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-card);
  border-color: rgba(85, 112, 248, 0.2);
}

.team-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  margin-bottom: 1.5rem;
}

.avatar-1 {
  background: linear-gradient(135deg, #eef2ff, #c7d2fe);
  color: #4f46e5;
}

.avatar-2 {
  background: linear-gradient(135deg, #ecfdf5, #a7f3d0);
  color: #059669;
}

.avatar-3 {
  background: linear-gradient(135deg, #fffbeb, #fde68a);
  color: #d97706;
}

.avatar-4 {
  background: linear-gradient(135deg, #fef2f2, #fecaca);
  color: #dc2626;
}

.avatar-5 {
  background: linear-gradient(135deg, #faf5ff, #e9d5ff);
  color: #9333ea;
}

.avatar-6 {
  background: linear-gradient(135deg, #f0fdf4, #bbf7d0);
  color: #16a34a;
}

.team-name {
  font-size: 1.2rem;
  color: #0b1120;
  margin-bottom: 0.5rem;
  font-weight: 700;
}

.team-role {
  color: #64748b;
  font-size: 0.95rem;
  font-weight: 500;
}

/* Responsive Team Section */
@media screen and (max-width: 768px) {
  .team-grid {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
}
@media screen and (max-width: 480px) {
  .team-grid {
    grid-template-columns: 1fr;
  }
}
